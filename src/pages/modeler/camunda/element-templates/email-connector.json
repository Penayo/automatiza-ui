[
  {
    "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
    "name": "SMTP Email Connector",
    "id": "io.camunda.connectors.EmailSendSMTP.v1",
    "description": "Send an Email via SMTP",
    "documentationRef": "https://docs.camunda.io/docs/components/modeler/web-modeler/connectors/available-connectors/smtp/",
    "icon": {
        "contents": "data:image/svg+xml;utf8,%3Csvg%20width%3D%2216%22%20height%3D%2216%22%20viewBox%3D%220%200%2016%2016%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%0A%3Cpath%20d%3D%22M0.285706%205.40847H5.43837V10.5611H0.285706V5.40847Z%22%20fill%3D%22white%22%2F%3E%0A%3Cpath%20d%3D%22M0.285706%205.40847H5.43837V10.5611H0.285706V5.40847Z%22%20fill%3D%22%2399E1F4%22%2F%3E%0A%3Cpath%20d%3D%22M5.43837%2010.5611L10.5611%2010.5616V15.6844H5.43837V10.5611Z%22%20fill%3D%22white%22%2F%3E%0A%3Cpath%20d%3D%22M5.43837%2010.5611L10.5611%2010.5616V15.6844H5.43837V10.5611Z%22%20fill%3D%22%2399E1F4%22%2F%3E%0A%3Cpath%20d%3D%22M0.285706%2015.6846L5.43837%2015.6844V15.7143H0.285706V15.6846ZM0.285706%2010.5619H5.43837V15.6844L0.285706%2015.6846V10.5619Z%22%20fill%3D%22%231A82E2%22%2F%3E%0A%3Cpath%20d%3D%22M5.43837%200.285706H10.5611V5.40847H5.43837V0.285706ZM10.5616%205.43837H15.7143V10.5611H10.5616V5.43837Z%22%20fill%3D%22%2300B3E3%22%2F%3E%0A%3Cpath%20d%3D%22M5.43837%2010.5611L10.5611%2010.5616V5.40847H5.43837V10.5611Z%22%20fill%3D%22%23009DD9%22%2F%3E%0A%3Cpath%20d%3D%22M10.5611%200.285706H15.7143V5.40847H10.5611V0.285706Z%22%20fill%3D%22%231A82E2%22%2F%3E%0A%3Cpath%20d%3D%22M10.5611%205.40847H15.7143V5.43837H10.5616L10.5611%205.40847Z%22%20fill%3D%22%231A82E2%22%2F%3E%0A%3C%2Fsvg%3E"
    },
    "appliesTo": [
        "bpmn:Task"
    ],
    "elementType": {
        "value": "bpmn:ServiceTask"
    },
    "groups": [
        {
            "id": "server-config",
            "label": "Server Config"
        },
        {
            "id": "authentication",
            "label": "Authentication"
        },
        {
            "id": "sender",
            "label": "Sender"
        },
        {
            "id": "receivers",
            "label": "Receivers"
        },
        {
            "id": "attachments",
            "label": "Attachments"
        },
        {
            "id": "retry-config",
            "label": "Retry Config"
        }
    ],
    "properties": [
        {
            "type": "Hidden",
            "value": "io.penayotech:smtp:1",
            "binding": {
                "type": "zeebe:taskDefinition:type"
            }
        },
        {
            "label": "Host",
            "group": "server-config",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "host"
            },
            "constraints": {
                "notEmpty": true
            }
        },
        {
            "label": "Port",
            "group": "server-config",
            "type": "Number",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "port"
            },
            "constraints": {
                "notEmpty": true
            }
        },
        {
            "label": "Secure",
            "group": "server-config",
            "type": "Boolean",
            "feel": "optional",
            "value": false,
            "binding": {
                "type": "zeebe:input",
                "name": "secure"
            }
        },
        {
            "label": "Service",
            "group": "server-config",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "service"
            }
        },
        {
            "label": "Type",
            "group": "authentication",
            "type": "Dropdown",
            "feel": "optional",
            "value": "login",
            "choices": [
                {
                    "name": "login",
                    "value": "login"
                },
                {
                    "name": "oauth2",
                    "value": "oauth2"
                }
            ],
            "binding": {
                "type": "zeebe:input",
                "name": "auth.type"
            }
        },
        {
            "label": "Username",
            "group": "authentication",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "auth.username"
            },
            "constraints": {
                "notEmpty": true
            }
        },
        {
            "label": "Password",
            "group": "authentication",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "auth.password"
            },
            "constraints": {
                "notEmpty": true
            }
        },
        {
            "label": "Auth Method",
            "group": "authentication",
            "type": "Dropdown",
            "feel": "optional",
            "value": "PLAIN",
            "choices": [
                {
                    "name": "PLAIN",
                    "value": "PLAIN"
                },
                {
                    "name": "LOGIN",
                    "value": "LOGIN"
                },
                {
                    "name": "CRAM-MD5",
                    "value": "CRAM-MD5"
                }
            ],
            "binding": {
                "type": "zeebe:input",
                "name": "auth.method"
            }
        },
        {
            "label": "Name",
            "group": "sender",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "sender.name"
            }
        },
        {
            "label": "Email Address",
            "group": "sender",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "sender.from"
            },
            "constraints": {
                "notEmpty": true
            }
        },
        {
            "label": "Subject",
            "group": "receivers",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "subject"
            }
        },
        {
            "label": "CC",
            "group": "receivers",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "cc"
            }
        },
        {
            "label": "BCC",
            "group": "receivers",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "bcc"
            }
        },
        {
            "label": "Email Address List",
            "group": "receivers",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "to"
            },
            "constraints": {
                "notEmpty": true
            }
        },
        {
            "label": "Template",
            "group": "receivers",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "template"
            }
        },
        {
            "label": "Body",
            "group": "receivers",
            "type": "Text",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "body"
            }
        },
        {
            "label": "Headers",
            "description": "Custom email headers as a key-value map. E.g. = {\"X-Priority\": \"1\"}",
            "group": "receivers",
            "type": "String",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "headers"
            }
        },
        {
            "label": "Attachments",
            "description": "List of attachments. Each item can be a file path string or an object with fields: filename, path, href, content, encoding, contentType. E.g. = [{filename: \"doc.pdf\", content: variables.pdfBase64, encoding: \"base64\", contentType: \"application/pdf\"}]",
            "group": "attachments",
            "type": "Text",
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "attachments"
            }
        },
        {
            "label": "Retries",
            "description": "Number of retry attempts on failure",
            "group": "retry-config",
            "type": "Number",
            "value": 3,
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "retries"
            }
        },
        {
            "label": "Retry Backoff",
            "description": "Backoff strategy between retries. E.g. exponential, fixed",
            "group": "retry-config",
            "type": "Dropdown",
            "value": "exponential",
            "choices": [
                {
                    "name": "Exponential",
                    "value": "exponential"
                },
                {
                    "name": "Fixed",
                    "value": "fixed"
                }
            ],
            "feel": "optional",
            "binding": {
                "type": "zeebe:input",
                "name": "retryBackoff"
            }
        }
    ]
    }
]